{
  "kind": "collectionType",
  "collectionName": "programs",
  "info": {
    "singularName": "program",
    "pluralName": "programs",
    "displayName": "Program"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "program_name": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "program_name"
    },
    "segment": {
      "type": "enumeration",
      "enum": [
        "monthly",
        "foundation",
        "private",
        "event"
      ]
    },
    "target_usia": {
      "type": "enumeration",
      "enum": [
        "kids",
        "junior",
        "teen",
        "adult",
        "all"
      ]
    },
    "description": {
      "type": "blocks"
    },
    "is_active": {
      "type": "boolean"
    },
    "thumbnail": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files"
      ]
    },
    "short_description": {
      "type": "string"
    },
    "age_targets": {
      "type": "component",
      "component": "shared.age-target",
      "repeatable": true
    },
    "showcase_image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos"
      ]
    },
    "program_gallery_item": {
      "type": "component",
      "component": "shared.program-gallery-item",
      "repeatable": true
    },
    "thumbnail_url": {
      "type": "string"
    }
  }
}
